# Default: auto-detect text vs. binary, store text with LF line endings.
# Working-tree files keep the OS-native ending on checkout.
* text=auto eol=lf

# Binary file types — never line-ending normalize, never diff as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.doc  binary
*.docx binary
*.xls  binary
*.xlsx binary
*.zip  binary
*.gz   binary
*.tar  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
