# Template for environment variables — copy to .env.local and fill in.
# .env.local is gitignored; this .env.example is committed as a reference
# of what keys the app expects.

# --- Supabase: browser-side (public; safe to bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase: server-side only (no VITE_ prefix) ---
# service_role bypasses RLS — keep out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase CLI helpers (server-side only) ---
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# --- Resend (server-side only; called from Supabase Edge Functions) ---
RESEND_API_KEY=

# --- Stripe ---
# Publishable key: browser-side (safe to bundle). Test keys begin with pk_test_
# and live keys with pk_live_. The VITE_ prefix exposes it to the client bundle.
VITE_STRIPE_PUBLISHABLE_KEY=

# Secret key: server-side only (Supabase Edge Functions). Test keys begin with
# sk_test_ and live keys with sk_live_. NEVER expose to the client.
STRIPE_SECRET_KEY=

# Webhook signing secret: server-side only. Used by Edge Functions to verify
# incoming Stripe webhook payloads. Begins with whsec_. One per endpoint —
# get it from the Stripe Dashboard > Developers > Webhooks > [endpoint] > Signing secret.
STRIPE_WEBHOOK_SECRET=

# Price identification: we use Stripe Price `lookup_key` (set on the Price
# itself in the Dashboard) rather than Price IDs in env. See the Edge Function
# `create-checkout-session` for the tier→lookup_key mapping.
