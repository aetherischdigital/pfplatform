# Template for environment variables — copy to .env.local and fill in.
# .env.local is gitignored; this .env.example is committed as a reference
# of what keys the app expects.

# --- Supabase: browser-side (public; safe to bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase: server-side only (no VITE_ prefix) ---
# service_role bypasses RLS — keep out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase CLI helpers (server-side only) ---
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# --- Resend (server-side only; called from Supabase Edge Functions) ---
RESEND_API_KEY=
